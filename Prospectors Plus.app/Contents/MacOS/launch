#!/bin/bash
# Launch the native Prospecting Macro app (its own window). Falls back to the
# browser settings UI automatically if pywebview isn't installed.
DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$DIR" || exit 1
for PY in /opt/homebrew/bin/python3 /usr/local/bin/python3 /usr/bin/python3; do
  [ -x "$PY" ] && exec "$PY" prospecting_app.py
done
P="$(command -v python3)"; [ -n "$P" ] && exec "$P" prospecting_app.py
osascript -e 'display alert "Python 3 not found" message "Install Python 3 (python.org or Homebrew) to use this app."'
